# Demo visual actual
DEMO_USER_EMAIL="ana@empresa.com"

# Forzar fallback demo aunque existan conexiones reales
USE_DEMO_REPOSITORY="false"

# MongoDB / Mongoose para reservas reales y usuarios de Auth.js
MONGODB_URI="mongodb://localhost:27017/salashermes"

# Auth.js
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# Prisma / PostgreSQL queda disponible como alternativa de persistencia
DATABASE_URL="postgresql://user:***@host:5432/salas"

# API protegida para un agente Hermes de Telegram
TELEGRAM_AGENT_API_TOKEN="reemplazar-por-token-largo-y-random"
TELEGRAM_AGENT_EMAIL="telegram-agent@empresa.com"
TELEGRAM_AGENT_NAME="Telegram Reservas Agent"
